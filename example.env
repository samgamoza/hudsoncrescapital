# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Project URL → SUPABASE_URL and VITE_SUPABASE_URL (same value)
# "anon public" key → SUPABASE_PUBLISHABLE_KEY and VITE_SUPABASE_PUBLISHABLE_KEY (same value)
#
# REQUIRED for server routes (e.g. /api/portal/asset-listings, admin queries): service role key
# Never commit the real value; never expose to browser bundles. Copy from API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here

# Alpha Vantage — https://www.alphavantage.co/support/#api-key
# If FINNHUB_* is also set, quotes + news use Finnhub first; unset Finnhub to force Alpha Vantage only.
# Free tier: strict daily/minute limits — full ticker refresh fans out many HTTP calls; cache in production.
ALPHA_VANTAGE_API_KEY=your_key_here

# Optional aliases if your code checks multiple names (pick one convention in server code)
# ALPHAVANTAGE_API_KEY=your_key_here
